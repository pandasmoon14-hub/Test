{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aetherforge.local/schemas/handoff/statblock_unit.schema.json",
  "allOf": [
    {"$ref": "content_unit.schema.json"},
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["statblock_validation_status"],
      "properties": {
        "unit_type": {"const": "statblock"},
        "statblock_validation_status": {"type": "string", "enum": ["validated", "partial", "failed", "queued"]}
      }
    }
  ]
}
