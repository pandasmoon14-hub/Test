{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AetherForgePageMetadata",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["page","chars","blocks","table_regions_detected","statblock_regions_detected","ocr_applied","source_page_hash","lane","page_marker_mode","audit"],
    "properties": {
      "page": {"type":"integer","minimum":1},
      "chars": {"type":"integer","minimum":0},
      "blocks": {"type":"integer","minimum":0},
      "detected_tables": {"type":"number"},
      "detected_columns": {"type":"boolean"},
      "table_regions_detected": {"type":"integer","minimum":0},
      "statblock_regions_detected": {"type":"integer","minimum":0},
      "ocr_applied": {"type":"boolean"},
      "source_page_hash": {"type":"string"},
      "repair": {"type":"object"},
      "lane": {"type":"string"},
      "page_marker_mode": {"type":"string"},
      "audit": {"type":"array","items":{"type":"string"}}
    }
  }
}
